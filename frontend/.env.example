# ===========================================
# RoamIQ Frontend Environment Configuration
# ===========================================

# API Base URL
VITE_API_URL=http://localhost:3000/api

# Google Maps API (required for maps features)
# Get your key at: https://console.cloud.google.com/google/maps-apis
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Supabase (optional - for real-time features)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# App Configuration
VITE_APP_NAME=RoamIQ
VITE_APP_URL=http://localhost:5173
