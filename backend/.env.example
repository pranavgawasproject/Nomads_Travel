# ============================================================
# RoamIQ Backend Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git!

# ── Server ────────────────────────────────────────────────────

PORT=3000

# ── Database ──────────────────────────────────────────────────

# MongoDB connection string (local or Atlas)
# Local:  mongodb://localhost:27017/roamiq
# Atlas:  mongodb+srv://<username>:<password>@cluster.mongodb.net/roamiq
MONGO_URL=mongodb://localhost:27017/roamiq

# ── JWT (MUST be strong, unique secrets — use `openssl rand -hex 64`) ────

# Access token: short-lived (1 hour). Used in Authorization header.
JWT_ACCESS_SECRET=replace_with_a_long_random_secret_at_least_64_chars_use_openssl_rand_hex_64

# Refresh token: long-lived (15 days). Used in httpOnly cookie.
JWT_REFRESH_SECRET=replace_with_a_different_long_random_secret_at_least_64_chars

# ── AWS S3 (file uploads) ─────────────────────────────────────

# Create an IAM user with S3FullAccess or limited S3 permissions.
# NEVER use root credentials — create a dedicated IAM user.
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1
AWS_BUCKET_NAME=roamiq-uploads

# ── Email (Nodemailer / SMTP) ──────────────────────────────────

# For Gmail: use an App Password (not your regular password)
# Enable 2FA → Account Settings → Security → App passwords
# https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password

# ── Client URL (for email links & CORS) ───────────────────────

# Used for password reset URLs and CORS whitelist
CLIENT_URL=http://localhost:5173
FRONTEND_PROD_LINK=https://your-production-domain.com/
FRONTEND_DEV_LINK=http://localhost:5173/

# ── Master Panel URL ──────────────────────────────────────────

# Base URL for the Master Panel API integration (used for syncing listings and POCs)
MASTER_PANEL_URL=http://localhost:5000