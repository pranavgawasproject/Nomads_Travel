# ===========================================
# RoamIQ Backend Environment Configuration
# ===========================================

# Server
PORT=3000
NODE_ENV=development

# MongoDB
MONGO_URL=mongodb://localhost:27017/roamiq
# Or use MongoDB Atlas:
# MONGO_URL=mongodb+srv://username:password@cluster.mongodb.net/roamiq

# JWT Authentication
JWT_ACCESS_SECRET=generate-a-strong-random-string-here
JWT_REFRESH_SECRET=another-strong-random-string-here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# AWS S3 (for file uploads)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_BUCKET_NAME=roamiq-uploads

# Google OAuth (optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Email (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Frontend URL (for CORS and email links)
CLIENT_URL=http://localhost:5173

# Supabase (optional - for alternative backend)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key
