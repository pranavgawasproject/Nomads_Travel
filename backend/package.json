{
  "name": "roamiq-backend",
  "version": "1.0.0",
  "description": "RoamIQ - AI-Powered Travel Intelligence Platform - Backend API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch"
  },
  "keywords": [
    "digital-nomad",
    "travel",
    "remote-work",
    "mern",
    "yc-w25"
  ],
  "author": "Pranav Gawas",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.862.0",
    "axios": "^1.11.0",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csv-parser": "^3.2.0",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "helmet": "^8.3.0",
    "jsonwebtoken": "^9.0.2",
    "libphonenumber-js": "^1.12.26",
    "mongoose": "^8.17.1",
    "multer": "^2.0.2",
    "nodemailer": "^7.0.6",
    "nodemon": "^3.1.11",
    "sharp": "^0.34.3",
    "yup": "^1.7.0"
  },
  "devDependencies": {
    "eslint": "^9.21.0",
    "jest": "^29.7.0",
    "supertest": "^7.1.0"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {},
    "testMatch": [
      "**/__tests__/**/*.test.js",
      "**/*.test.js"
    ],
    "moduleFileExtensions": [
      "js",
      "mjs"
    ],
    "collectCoverageFrom": [
      "controllers/**/*.js",
      "routes/**/*.js",
      "models/**/*.js",
      "middlewares/**/*.js"
    ],
    "coverageDirectory": "coverage",
    "verbose": true
  }
}
